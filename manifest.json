{
  "manifest_version": 3,
  "name": "CanvasClip",
  "version": "1.0.0",
  "description": "Clipboard bridge for browser-based remote desktops rendered into a canvas. Types text into the session when paste doesn't work, and OCRs a screen region when copy doesn't work.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "offscreen", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "CanvasClip",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
